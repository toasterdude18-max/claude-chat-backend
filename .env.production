NODE_ENV=production
PORT=3000
BACKEND_URL=https://your-vercel-project.vercel.app

# Claude API Key (OpenRouter)
CLAUDE_API_KEY=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

# CORS Origins (localhost for development, will update after Vercel deployment)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# QR Token Expiry (minutes)
QR_TOKEN_EXPIRY_MINUTES=5

# Note: Firebase is not used in this deployment (using in-memory storage)
